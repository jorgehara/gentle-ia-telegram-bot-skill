# Telegram Bridge Configuration
# Copiá este archivo como .env y completá con tus valores

# REQUIRED - Token de tu bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# SECURITY - Lista de Chat IDs permitidos (vacío = todos)
# Para obtener tu Chat ID, enviale /id al bot
# Formato: ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# OpenCode Server URL (default: http://localhost:4096)
OPENCODE_URL=http://localhost:4096

# OpenCode Authentication (optional)
# OPENCODE_USERNAME=opencode
# OPENCODE_PASSWORD=tu_password_aqui

# Project directory para sesiones de OpenCode (default: .)
OPENCODE_PROJECT_DIR=.

# HTTP server port para el bridge (default: 8080)
BRIDGE_PORT=8080

# Enable Markdown in responses (default: true)
ENABLE_MARKDOWN=true

# Debug mode (default: false)
DEBUG=false